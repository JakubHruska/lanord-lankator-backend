# Zkopíruj tento soubor jako .env a vyplň hodnoty
# cp .env.example .env

# Produkční hodnoty pro Proxmox VM (10.0.20.240)
DEBUG=False
SECRET_KEY=ZMEN_TOTO_NA_SILNY_NAHODNY_KLIC

# Povolené hosty (oddělené čárkou)
ALLOWED_HOSTS=10.0.20.240,localhost

# Cesta k mediálním souborům uvnitř kontejneru (Samba mountovaná na /app/media)
MEDIA_PATH=/app/media

# CORS – povolené origins frontendu (oddělené čárkou)
CORS_ALLOWED_ORIGINS=http://10.0.20.240

